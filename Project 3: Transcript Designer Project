import random
import csv
from collections import defaultdict

from genedesign.rbs_chooser import RBSChooser
from genedesign.models.transcript import Transcript
from genedesign.checkers.codon_checker import CodonChecker
from genedesign.checkers.forbidden_sequence_checker import ForbiddenSequenceChecker
from genedesign.checkers.internal_promoter_checker import PromoterChecker
from genedesign.checkers.hairpin_checker import hairpin_checker
from genedesign.checkers.gc_content_checker import GCContentChecker


class TranscriptDesigner:
    """
    Reverse translates a protein sequence into a codon-optimized DNA sequence
    and chooses an RBS.  Integrates all quality checkers and performs targeted
    repair when forbidden sequences or internal promoters are detected.
    
    Improvement over v2: after initial codon selection, runs checkers and
    does targeted codon swaps to fix forbidden restriction sites and
    internal sigma-70 promoters.
    """

    def __init__(self):
        self.aa_to_codons = {}
        self.codon_to_aa = {}
        self.rare_codons = set()
        self.rbsChooser = None
        self.forbiddenChecker = None
        self.promoterChecker = None
        self.gcChecker = None

    def initiate(self) -> None:
        """
        Loads codon usage data and initialises all sub-components.
        """
        self.rbsChooser = RBSChooser()
        self.rbsChooser.initiate()

        self.forbiddenChecker = ForbiddenSequenceChecker()
        self.forbiddenChecker.initiate()

        self.promoterChecker = PromoterChecker()
        self.promoterChecker.initiate()

        self.gcChecker = GCContentChecker()
        self.gcChecker.initiate()

        # Load codon usage data
        codon_usage_file = 'genedesign/data/codon_usage.txt'
        raw = defaultdict(list)
        with open(codon_usage_file, 'r') as f:
            reader = csv.reader(f, delimiter='\t')
            for row in reader:
                if len(row) < 4:
                    continue
                codon = row[0].strip()
                aa = row[1].strip()
                freq = float(row[2].strip())
                if aa == '*':
                    continue
                raw[aa].append((codon, freq))
                self.codon_to_aa[codon] = aa

        self.aa_to_codons = {}
        for aa, codon_list in raw.items():
            self.aa_to_codons[aa] = sorted(codon_list, key=lambda x: -x[1])

        self.rare_codons = set()
        for aa, codon_list in self.aa_to_codons.items():
            for codon, freq in codon_list:
                if freq < 0.10:
                    self.rare_codons.add(codon)

    def _weighted_random_codon(self, aa: str) -> str:
        """Pick a codon weighted by usage frequency, excluding rare codons."""
        options = self.aa_to_codons[aa]
        good = [(c, w) for c, w in options if c not in self.rare_codons]
        if not good:
            good = options
        codons = [c for c, _ in good]
        weights = [w for _, w in good]
        return random.choices(codons, weights=weights, k=1)[0]

    def _alternate_codon(self, codon: str) -> str:
        """Return a different synonymous codon, avoiding rare codons."""
        aa = self.codon_to_aa.get(codon)
        if aa is None:
            return codon
        options = self.aa_to_codons[aa]
        if len(options) <= 1:
            return codon
        good = [(c, w) for c, w in options if c not in self.rare_codons and c != codon]
        if not good:
            good = [(c, w) for c, w in options if c != codon]
        if not good:
            return codon
        codons_list = [c for c, _ in good]
        weights = [w for _, w in good]
        return random.choices(codons_list, weights=weights, k=1)[0]

    def _initial_codons(self, peptide: str) -> list:
        """Generate initial codons using weighted random selection."""
        codons = [self._weighted_random_codon(aa) for aa in peptide]
        codons.append("TAA")
        return codons

    def _find_site_codon_range(self, codons, rbs_utr, site):
        """Find the codon index range overlapping a detected site."""
        cds = ''.join(codons)
        transcript_dna = rbs_utr.upper() + cds
        utr_len = len(rbs_utr)
        pos = transcript_dna.upper().find(site.upper())
        if pos == -1:
            return None
        cds_start = max(0, pos - utr_len)
        cds_end = min(len(cds), cds_start + len(site) + 3)
        codon_start = max(0, cds_start // 3 - 1)
        codon_end = min(len(codons) - 1, cds_end // 3 + 1)
        return codon_start, codon_end

    def _fix_forbidden(self, codons, rbs_utr):
        """Swap codons overlapping a forbidden restriction site."""
        passed, site = self.forbiddenChecker.run(rbs_utr.upper() + ''.join(codons))
        if passed or site is None:
            return codons
        rng = self._find_site_codon_range(codons, rbs_utr, site)
        if rng is None:
            return codons
        start, end = rng
        for i in range(start, end):
            codons[i] = self._alternate_codon(codons[i])
        return codons

    def _fix_promoter(self, codons, rbs_utr):
        """Swap codons overlapping a detected internal promoter."""
        passed, found_seq = self.promoterChecker.run(rbs_utr.upper() + ''.join(codons))
        if passed or found_seq is None:
            return codons
        rng = self._find_site_codon_range(codons, rbs_utr, found_seq)
        if rng is None:
            return codons
        start, end = rng
        for i in range(start, end):
            codons[i] = self._alternate_codon(codons[i])
        return codons

    def run(self, peptide: str, ignores: set) -> Transcript:
        """
        Designs a codon-optimized CDS with targeted repair.
        
        Steps:
          1. Generate initial codons via weighted random selection.
          2. Choose an RBS.
          3. Iteratively fix forbidden sequences and internal promoters.
          4. Restart if needed; return the best result found.
        """
        MAX_RESTARTS = 3

        best_codons = None
        best_rbs = None
        best_passes = -1

        for _restart in range(MAX_RESTARTS):
            codons = self._initial_codons(peptide)
            cds = ''.join(codons)
            selectedRBS = self.rbsChooser.run(cds, ignores)
            rbs_utr = selectedRBS.utr

            # Targeted repair loops
            for _ in range(10):
                passed_f, _ = self.forbiddenChecker.run(rbs_utr.upper() + ''.join(codons))
                if passed_f:
                    break
                codons = self._fix_forbidden(codons, rbs_utr)

            for _ in range(10):
                passed_p, _ = self.promoterChecker.run(rbs_utr.upper() + ''.join(codons))
                if passed_p:
                    break
                codons = self._fix_promoter(codons, rbs_utr)

            # Score this attempt
            tdna = rbs_utr.upper() + ''.join(codons)
            score = sum([
                self.forbiddenChecker.run(tdna)[0],
                self.promoterChecker.run(tdna)[0],
                hairpin_checker(tdna)[0],
                self.gcChecker.run(''.join(codons))[0],
            ])

            if score > best_passes:
                best_passes = score
                best_codons = list(codons)
                best_rbs = selectedRBS

            if score == 4:
                return Transcript(selectedRBS, peptide, codons)

        return Transcript(best_rbs, peptide, best_codons)


if __name__ == "__main__":
    from genedesign.checkers.codon_checker import CodonChecker
    from genedesign.seq_utils.Translate import Translate

    peptide = ""

    designer = TranscriptDesigner()
    designer.initiate()
    transcript = designer.run(peptide, set())
    cds = ''.join(transcript.codons)

    translator = Translate(); translator.initiate()
    print(f"Protein match: {translator.run(cds) == peptide}")

    cc = CodonChecker(); cc.initiate()
    cab, div, rare, cai = cc.run(transcript.codons)
    print(f"Codon: passes={cab}, diversity={div:.3f}, rare={rare}, CAI={cai:.3f}")

    fc = ForbiddenSequenceChecker(); fc.initiate()
    print(f"Forbidden: {fc.run(cds)[0]}")

    pc = PromoterChecker(); pc.initiate()
    print(f"Promoter: {pc.run(cds)[0]}")

    print(f"Hairpin: {hairpin_checker(cds)[0]}")
